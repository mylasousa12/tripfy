### OpenResty #################################################

OPENRESTY_HOST_HTTP_PORT=80
OPENRESTY_HOST_HTTPS_PORT=443
OPENRESTY_HOST_LOG_PATH=./infra/docker/logs/openresty/
OPENRESTY_SITES_PATH=./infra/docker/openresty/sites/
OPENRESTY_PHP_UPSTREAM_CONTAINER=php-fpm
OPENRESTY_PHP_UPSTREAM_PORT=9000
OPENRESTY_SSL_PATH=./infra/docker/openresty/ssl/

### POSTGRES ##############################################

POSTGRES_VERSION=17
POSTGRES_CLIENT_VERSION=15
POSTGRES_DB=default
POSTGRES_USER=postgre
POSTGRES_PASSWORD=secret
POSTGRES_PORT=5432
POSTGRES_ENTRYPOINT_INITDB=./infra/docker/postgres/docker-entrypoint-initdb.d
